<?xml version="1.0" ?>
<launch>
  <!--
    Logger node ONLY.
    NOTE: Prefer using kitting_state_controller.launch with record:=true instead.
    This launch file is kept for backward compatibility.
  -->
  <arg name="base_directory" default="~/kitting_bags" />
  <arg name="object_name" default="default_object" />
  <arg name="export_csv_on_stop" default="true" />

  <node name="kitting_logger" pkg="franka_kitting_controller" type="kitting_logger" output="screen">
    <rosparam command="load" file="$(find franka_kitting_controller)/config/kitting_logger.yaml" subst_value="true" />
    <param name="base_directory" value="$(arg base_directory)" />
    <param name="object_name" value="$(arg object_name)" />
    <param name="export_csv_on_stop" value="$(arg export_csv_on_stop)" />
  </node>
</launch>
